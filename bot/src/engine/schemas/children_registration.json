{
  "tenantId": "children",
  "initialState": "start",
  "states": {
    "start": {
      "id": "start",
      "entryActions": ["promptLanguage"],
      "transitions": [
        { "event": "language_selected", "to": "children_welcome", "actions": ["sendWelcome"] }
      ]
    },
    "children_welcome": {
      "id": "children_welcome",
      "entryActions": ["promptFullName"],
      "transitions": [
        { "event": "full_name_provided", "to": "collectionFullName", "actions": ["validateFullName"] }
      ]
    },
    "collectionFullName": {
      "id": "collectionFullName",
      "entryActions": [],
      "transitions": [
        { "event": "full_name_valid", "to": "children_collectionPhone", "actions": ["promptPhone"] },
        { "event": "full_name_invalid", "to": "collectionFullName", "actions": ["promptFullNameError"] }
      ]
    },
    "children_collectionPhone": {
      "id": "children_collectionPhone",
      "entryActions": [],
      "transitions": [
        { "event": "phone_provided", "to": "children_collectionCity", "actions": ["promptCity"] }
      ]
    },
    "children_collectionCity": { "id": "children_collectionCity" }
  },
  "actions": {
    "promptLanguage": { "type": "sendL10n", "params": { "key": "selectLanguage" } },
    "sendWelcome": { "type": "sendL10n", "params": { "key": "welcome" } },
    "promptFullName": { "type": "sendL10n", "params": { "key": "enterFirstNameLastNameAndBirthYear" } },
    "promptFullNameError": { "type": "sendL10n", "params": { "key": "enterFirstNameLastNameAndBirthYearError" } },
    "validateFullName": { "type": "validateFullName" },
    "promptPhone": { "type": "sendL10n", "params": { "key": "enterPhoneNumber" } },
    "promptCity": { "type": "sendL10n", "params": { "key": "enterCity" } }
  }
}
